# Purpose: Example environment configuration for the MarketAnalysis app.
# Copy this file to `.env` and fill in the values you want to enable.

# Required for AI analysis via xAI / Grok.
# You can use either the canonical names or the LOCAL_* aliases already supported by ui/server.js.
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-4.3

# Optional alias pair if you prefer local-only naming.
# LOCAL_XAI_API_KEY=your_xai_api_key_here
# LOCAL_GROK_MODEL=grok-4.3

# Optional server settings.
HOST=127.0.0.1
PORT=8787

# Optional: force a specific Python interpreter for PDF generation on Windows.
# MARKET_PYTHON=C:\APPS_NEW\DeepTutor\.venv\Scripts\python.exe

# Optional: choose the analysis engine.
# Supported in current code: auto, xai
ANALYSIS_ENGINE=auto

# Optional xAI API base override.
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_API_BASE=https://api.x.ai/v1

# Optional market data API overrides.
# BINANCE_API_BASE=https://api.binance.com
# COINGECKO_API_BASE=https://api.coingecko.com/api/v3
# XRPSCAN_API_BASE=https://api.xrpscan.com/api/v1

# Optional CoinGecko API key.
# Any one of these names is accepted.
# COINGECKO_API_KEY=your_coingecko_api_key_here
# COINGECKO_DEMO_API_KEY=your_coingecko_demo_key_here
# X_CG_DEMO_API_KEY=your_coingecko_demo_key_here

# Optional CoinMarketCap enrichment for crypto reports.
# Either name is accepted.
# CMC_API_KEY=your_coinmarketcap_api_key_here
# COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# Optional X / Twitter social sentiment enrichment for crypto reports.
# Either bearer token name is accepted.
# X_BEARER_TOKEN=your_x_bearer_token_here
# TWITTER_BEARER_TOKEN=your_x_bearer_token_here

# Optional metadata only. Current code does not require this.
# X_ACCOUNT_HANDLE=your_x_handle_without_at
